{
  "download_folders": {
    "type": "list",
    "default": [],
    "description": "视频下载目录列表",
    "items": {
      "type": "string"
    }
  },
  "cookie_file": {
    "type": "file",
    "default": [],
    "file_types": ["txt"],
    "description": "yt-dlp cookies 文件",
    "hint": "上传 cookies.txt 文件用于认证"
  },
  "enable_archive": {
    "type": "bool",
    "default": true,
    "description": "启用下载存档"
  },
  "video_seperate_folder": {
    "type": "bool",
    "default": false,
    "description": "每个视频单独文件夹"
  },
  "video_proxy": {
    "type": "bool",
    "default": false,
    "description": "启用代理"
  },
  "video_proxy_url": {
    "type": "string",
    "default": "",
    "description": "代理地址",
    "hint": "Format: http://host:port or socks5://host:port"
  },
  "rclone_upload": {
    "type": "bool",
    "default": false,
    "description": "启用 rclone 上传"
  },
  "rclone_server": {
    "type": "string",
    "default": "",
    "description": "rclone 远程名称",
    "hint": "Remote name configured in rclone"
  },
  "rclone_folders": {
    "type": "list",
    "default": [],
    "description": "rclone 上传目录列表",
    "items": {
      "type": "string"
    }
  }
}
